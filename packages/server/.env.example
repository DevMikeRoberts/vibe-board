# Server port (default: 8080)
PORT=8080

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:4175,http://localhost:4176

# --- Database ---
# SQLite (default) — set DB_PATH to change the file location
DB_PATH=./data/agentboard.db

# PostgreSQL — set DATABASE_URL to use Postgres instead of SQLite
# DATABASE_URL=postgresql://agentboard:your_password@localhost:5432/agentboard

# --- Agent models (optional) ---
# COPILOT_MODEL=claude-opus-4-20250514
# CLAUDE_MODEL=claude-opus-4-20250514
# CODEX_MODEL=gpt-5.2-codex

# --- Authentication ---
# Set API_KEY to require Bearer token auth on all API and WebSocket requests.
# Leave unset for open access (local dev). Must match VITE_API_KEY on the client.
# API_KEY=your-secret-key

# GitHub personal access token for auto-loading your repositories on startup.
# Leave unset to skip auto-load. Token needs 'repo' scope to list your repositories.
# When set, all your personal (non-fork) repositories will be automatically
# loaded as projects if they are not already present in the board.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx

# --- Security ---
# Comma-separated allowed repo root paths for agent file access
# POSIX example:
# ALLOWED_REPO_ROOTS=/home/you/projects,/tmp
# Windows example:
# ALLOWED_REPO_ROOTS=D:\git,C:\Users\you,C:\Users\you\AppData\Local\Temp

# Max agent execution time in milliseconds (default: 600000 = 10 min)
# AGENT_TIMEOUT_MS=600000
